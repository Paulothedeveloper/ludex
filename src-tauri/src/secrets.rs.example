// Copy this file to `secrets.rs` and fill in the real Gumroad credentials.
// `secrets.rs` is in .gitignore so the access token never lands in source control.
//
// Where to get these values:
//   - GUMROAD_PRODUCT_ID:   the slug at the end of your product URL
//                           (ex: "https://you.gumroad.com/l/ludex" -> "ludex")
//   - GUMROAD_ACCESS_TOKEN: Gumroad dashboard -> Settings -> Avancado ->
//                           Aplicativos -> Create application ->
//                           Generate access token
//   - GUMROAD_PERMALINK:    full public URL of the product (used for the
//                           "Comprar agora" button on the license gate)

pub const GUMROAD_PRODUCT_ID:   &str = "PLACEHOLDER_PRODUCT_PERMALINK";
pub const GUMROAD_ACCESS_TOKEN: &str = "PLACEHOLDER_ACCESS_TOKEN";
pub const GUMROAD_PERMALINK:    &str = "https://your-store.gumroad.com/l/your-product";

// Email do comprador admin. Quando o Gumroad responde uma verify e o
// `purchase.email` bate com esse valor, o frontend mostra o botao "Painel
// Admin" no Settings. Sem bypass de seguranca — eh apenas flag de UI.
pub const ADMIN_EMAIL:          &str = "your-email@example.com";

// === FASE C — servidor de token assinado (opcional, recomendado) ============
// Suba o Worker em server/ (ver server/README.md). Cole aqui a URL publicada
// e a CHAVE PUBLICA (hex, 32 bytes) cujo par privado virou secret do Worker.
// Com placeholders, o app continua falando com o Gumroad direto (modo legado).
pub const LICENSE_SERVER_URL:     &str = "https://PLACEHOLDER.workers.dev";
pub const LICENSE_PUBLIC_KEY_HEX: &str = "PLACEHOLDER_PUBKEY_HEX";
