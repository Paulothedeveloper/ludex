// v1.1.0: o app NAO fala com o Gumroad direto. Quem valida a key e o Worker em
// server/ (ver server/README.md), que guarda o token do Gumroad como secret.
// Aqui so ficam valores publicos:

// URL publica do produto no Gumroad (botao "Comprar agora" no gate de licenca).
pub const GUMROAD_PERMALINK:      &str = "https://your-store.gumroad.com/l/your-product";

// Worker de licenca (server/). Cole a URL publicada e a CHAVE PUBLICA (hex, 32
// bytes) cujo par privado virou secret do Worker. Ver server/README.md.
pub const LICENSE_SERVER_URL:     &str = "https://PLACEHOLDER.workers.dev";
pub const LICENSE_PUBLIC_KEY_HEX: &str = "PLACEHOLDER_PUBKEY_HEX";
